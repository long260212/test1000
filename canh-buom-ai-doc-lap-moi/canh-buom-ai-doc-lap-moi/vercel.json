{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "COREPACK_ENABLE_DOWNLOAD_PROMPT=0 corepack npm ci --no-audit --no-fund",
  "buildCommand": "corepack npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.ts": {
      "maxDuration": 30
    }
  }
}
